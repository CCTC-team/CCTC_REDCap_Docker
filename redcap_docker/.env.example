# REDCap version - must match a directory under redcap_source/ (e.g., redcap_v15.5.33)
REDCAP_VERSION=15.5.36

# Database credentials
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=redcap

# REDCap salt (alphanumeric, 8+ chars - do NOT change after first install)
REDCAP_SALT=12345678

# Port mappings
REDCAP_HTTP_PORT=8080
REDCAP_HTTPS_PORT=8443
MYSQL_PORT=3400
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025
