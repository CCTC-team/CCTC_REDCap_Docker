# Copy to .env: cp .env.example .env

# REDCap version - must match a directory under redcap_source/ (e.g. redcap_v15.5.36)
REDCAP_VERSION=15.5.36

# Built image tag -> image is cctc/redcap-${REDCAP_VERSION}:${REDCAP_IMAGE_TAG}
REDCAP_IMAGE_TAG=v1.0.0

# Database
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=redcap

# REDCap salt (do NOT change after first install)
REDCAP_SALT=12345678

# Host port mappings
REDCAP_HTTP_PORT=8080
REDCAP_HTTPS_PORT=8443
MYSQL_PORT=3400
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025

# --- Prebuilt image (optional) -------------------------------------------------
# Uncomment to RUN a prebuilt image pulled from GHCR instead of building locally.
# Then: docker compose pull && docker compose up -d
#REDCAP_IMAGE=ghcr.io/cctc-team/cctc_redcap_docker/redcap-aio:15.5.36
