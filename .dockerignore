# Exclude git history
.git/
**/.git/

# Exclude Cypress test suite (large, not needed in the image)
redcap_cypress/
CCTC_REDCap_Docker/volumes/

# Exclude writable data directories (created at runtime by entrypoint)
redcap_source/edocs/
redcap_source/temp/
redcap_source/redcap_file_repository/

# Exclude self-signed certs (generated at build time inside the image)
CCTC_REDCap_Docker/mycert.crt
CCTC_REDCap_Docker/mycert.key

# Exclude docs and misc
*.md
*.xlsx
*.csv
Docs/
